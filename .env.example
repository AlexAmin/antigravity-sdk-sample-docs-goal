# --- Gemini (agent brain) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Developer Knowledge API (optional) ---
# Used by the `researcher` subagent's search_developer_knowledge tool to look up official
# Google docs via the Developer Knowledge REST API (developerknowledge.googleapis.com).
# Auth: set an API key here, OR leave blank to use Application Default Credentials
# (gcloud auth application-default login / the service account above). If neither
# authenticates, the tool returns a "not authenticated" message and the demo still runs.
DEV_KNOWLEDGE_API_KEY=

# --- Google Docs API auth ---
# Simplest path for a public demo: a service account, with the target doc
# shared to its email as Editor. (Alternative: user OAuth — see AGENTS.md.)
# The doc to edit is chosen in the Sidebar per run, not here.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
